name: Swap Index and Title Files

on:
  schedule:
    # 12:00 PM JST is 03:00 AM UTC (Runs daily at 03:00 UTC)
    - cron: '0 3 * * *'
  
  # Allows manual testing from the Actions tab
  workflow_dispatch:

jobs:
  swap:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Git config
        run: |
          git config --global user.name "GitHub Actions Bot"
          git config --global user.email "actions@github.com"

      - name: Perform file swap
        run: |
          # Step 1: Move current index.html out of the way to a temp file
          git mv index.html temp_index.html
          
          # Step 2: Rename title.html to index.html
          git mv title.html index.html
          
          # Step 3: Rename the old index (temp) to index2.html
          git mv temp_index.html index2.html

      - name: Commit and push changes
        run: |
          git add -A
          git commit -m "Automated file swap: title.html becomes index.html at 12:00 PM JST"
          git push
